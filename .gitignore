# --- environment / editor ---
.env
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
*.egg-info/
.streamlit/secrets.toml

# Archive of legacy code from earlier project phases. Not part of the canonical
# pipeline. Kept on local disk for reference; not shipped.
_archive/

# Developer notes — audit log, v3 plans, etc. Working artefacts that
# aren't part of the submission.
docs/dev/

# --- generated documents (PDFs render from .md, never commit) ---
docs/*.pdf

# --- generated data (the code generates this; GitHub is for code) ---
# Whole repo-root data/ tree is gitignored. Source code + manifests live under
# src/data/. Anything under /data/ is fetched / cached / scratch material that
# the code regenerates: pair pulls (data/pairs/), per-track windows
# (data/video/), external dataset drops (data/external/cadc/, etc.), recon
# CSVs, raw frames.
/data/


# --- runtime outputs (regenerable from `make`) ---
# Static-prior heroes: regenerated by `make stills` (panels, contact-sheet, summary).
outputs/nordic_stills/*.png
outputs/nordic_stills/*.jpg
outputs/nordic_stills/summary.json
outputs/cache/
outputs/audit/
outputs/_video_frames/
outputs/*.log
outputs/*.pid

# Phase K (video) — every render and intermediate cache is regenerable.
outputs/toronto_video/

# Live `make demo SNOW=... PRIOR=...` outputs — regenerable.
outputs/demo/

# --- defensive: never commit large binary blobs anywhere in data/ or outputs/ ---
# (overrides the broad data/video/ rule above only for the patterns themselves)
**/*.mp4
**/*.mov
**/*.zip
**/*.tar
**/*.tar.gz
**/*.7z
**/*.pkl
**/*.parquet
data/**/*.csv
outputs/**/*.csv

# Site media: hand-staged stills and clips that the GitHub Pages site loads.
# These are the only binaries that ship in the repo.
!docs/_assets/media/**

# Claude Code agent state (local-only)
.claude/
