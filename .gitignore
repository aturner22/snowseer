.env
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
data/pairs/
data/raw/
# Track INDEX.md but not the (large, regenerable) panel/baseline/match PNGs.
outputs/heroes/*.png
outputs/heroes/*.jpg
outputs/cache/
outputs/audit/
outputs/_video_frames/
outputs/pipeline_run.log
outputs/fetch_v2.log
outputs/fetch_*.log
.streamlit/secrets.toml
*.egg-info/
# Phase K (video) — raw clips and renders are large + regenerable.
# Defensive: ignore everything large under data/video/ and outputs/video/
# while still allowing the small per-track metadata (camera_poses.csv,
# window.json, track.json, calib/) to be tracked.

# Bulk data — never commit
data/video/snow/
data/video/priors/
data/video/_finnish_winter/
data/video/tracks/**/frames/

# Per-track outputs — never commit
outputs/video/**/*.mp4
outputs/video/*/frames/

# Caches and intermediate pickles
outputs/video/**/_cache_*.pkl
outputs/video/**/_aug_*.pkl
outputs/video/**/*.pkl

# Composer / renderer working dirs
outputs/video/**/_compose_work/

# Background-task logs (any underscore-prefixed log under outputs/video/)
outputs/video/_*.log

# General defensive: never commit zip / tar / 7z anywhere in data/ or outputs/
data/**/*.zip
data/**/*.tar
data/**/*.tar.gz
data/**/*.7z
outputs/**/*.zip
outputs/**/*.tar
outputs/**/*.tar.gz
outputs/**/*.7z
