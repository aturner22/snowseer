# --- environment / editor ---
.env
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
*.egg-info/
.streamlit/secrets.toml

# Archive of legacy code from earlier project phases. Not part of the canonical
# pipeline. Kept on local disk for reference; not shipped.
_archive/

# --- generated documents (PDFs render from .md, never commit) ---
docs/*.pdf

# --- generated data (the code generates this; GitHub is for code) ---
# Whole data/ tree is gitignored. Source code + manifests live under src/data/.
# Anything under data/ is fetched / cached / scratch material that the code
# regenerates: pair pulls (data/pairs/), per-track windows (data/video/),
# external dataset drops (data/external/cadc, etc.), recon CSVs, raw frames.
data/

# --- submission bundle (local-only; populated by `make submission-bundle`) ---
submission/

# --- runtime outputs (regenerable from `make`) ---
# Static-prior heroes: regenerated by `make stills` (panels, contact-sheet, summary).
outputs/heroes/*.png
outputs/heroes/*.jpg
outputs/heroes/summary.json
outputs/cache/
outputs/audit/
outputs/_video_frames/
outputs/pipeline_run.log
outputs/fetch_v2.log
outputs/fetch_*.log
outputs/_*.log

# Phase K (video) — every render and intermediate cache is regenerable.
outputs/video/

# Live `make demo SNOW=... PRIOR=...` outputs — regenerable.
outputs/demo/

# --- defensive: never commit large binary blobs anywhere in data/ or outputs/ ---
# (overrides the broad data/video/ rule above only for the patterns themselves)
**/*.mp4
**/*.mov
**/*.zip
**/*.tar
**/*.tar.gz
**/*.7z
**/*.pkl
**/*.parquet
data/**/*.csv
outputs/**/*.csv
